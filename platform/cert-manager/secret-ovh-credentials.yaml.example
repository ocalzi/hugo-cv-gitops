# OVH credentials secret for cert-manager DNS-01 webhook.
# Copy to secret-ovh-credentials.yaml, fill in values, apply — do NOT commit the filled file.
#
# Get credentials at: https://api.ovh.com/createApp/
# Required rights: GET/POST/PUT on /domain/zone/*
#
# Apply with: kubectl apply -f secret-ovh-credentials.yaml -n cert-manager

apiVersion: v1
kind: Secret
metadata:
  name: letsencrypt-prod-dns01-ovh-credentials
  namespace: cert-manager
type: Opaque
stringData:
  applicationKey: "YOUR_OVH_APP_KEY"
  applicationSecret: "YOUR_OVH_APP_SECRET"
  applicationConsumerKey: "YOUR_OVH_CONSUMER_KEY"
