# Gitea runner registration token.
# Copy to secret-runner.yaml, fill in token, apply — do NOT commit the filled file.
#
# Get token from: Gitea → Site Administration → Runners → Create Runner

apiVersion: v1
kind: Secret
metadata:
  name: runner-secret
  namespace: gitea-runner
type: Opaque
stringData:
  token: "YOUR_GITEA_RUNNER_REGISTRATION_TOKEN"
