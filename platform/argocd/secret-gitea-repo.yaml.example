# ArgoCD repository credentials — works with any Git provider (Gitea, GitHub, GitLab).
# Only needed for private repos. Public GitHub/GitLab repos require no secret.
# Copy to /tmp/secret-repo.yaml, fill in values, apply — do NOT commit the filled file.
#
# Apply with: kubectl apply -f /tmp/secret-repo.yaml -n argocd

apiVersion: v1
kind: Secret
metadata:
  name: gitea-gitops-repo
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: YOUR_GITEA_URL/YOUR_ORG/gitops
  username: YOUR_GITEA_USERNAME
  password: YOUR_GITEA_TOKEN  # Gitea → Settings → Applications → Generate Token
