# ArgoCD repository credentials for your Gitea instance.
# Copy to secret-gitea-repo.yaml, fill in values, apply — do NOT commit the filled file.
#
# Apply with: kubectl apply -f secret-gitea-repo.yaml -n argocd

apiVersion: v1
kind: Secret
metadata:
  name: gitea-gitops-repo
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: YOUR_GITEA_URL/YOUR_ORG/gitops
  username: YOUR_GITEA_USERNAME
  password: YOUR_GITEA_TOKEN  # Gitea → Settings → Applications → Generate Token
